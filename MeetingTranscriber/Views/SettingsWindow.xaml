<Window x:Class="MeetingTranscriber.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - Meeting Transcriber"
        Width="520" Height="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Azure AI Foundry Settings"
                   FontSize="18" FontWeight="SemiBold" Foreground="#CDD6F4" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Endpoint URL:"
                   Foreground="#BAC2DE" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="EndpointBox"
                 Margin="0,0,0,8" Padding="6,4"
                 Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Authentication:"
                   Foreground="#BAC2DE" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="EntraAuthCheckBox"
                  Content="Use Microsoft Entra ID"
                  Foreground="#BAC2DE" Margin="0,0,0,8" VerticalAlignment="Center"
                  Checked="EntraAuthCheckBox_Changed" Unchecked="EntraAuthCheckBox_Changed"/>

        <!-- Sign-in row (visible only when Entra auth is checked) -->
        <StackPanel Grid.Row="3" Grid.Column="1" x:Name="SignInPanel" Orientation="Horizontal"
                    Margin="0,0,0,8">
            <Button x:Name="SignInButton" Content="🔐 Sign In" Click="SignIn_Click"
                    Width="100" Height="28"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"/>
            <TextBlock x:Name="SignInStatus" Foreground="#A6E3A1" FontSize="12"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Grid.Column="0" x:Name="ApiKeyLabel" Text="API Key:"
                   Foreground="#BAC2DE" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="ApiKeyBox"
                     Margin="0,0,0,8" Padding="6,4"
                     Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Whisper Deployment:"
                   Foreground="#BAC2DE" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="WhisperBox"
                 Margin="0,0,0,8" Padding="6,4"
                 Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Chat Deployment:"
                   Foreground="#BAC2DE" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="ChatBox"
                 Margin="0,0,0,8" Padding="6,4"
                 Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"/>

        <!-- Startup options -->
        <TextBlock Grid.Row="6" Grid.ColumnSpan="2" Text="Startup"
                   FontSize="18" FontWeight="SemiBold" Foreground="#CDD6F4" Margin="0,12,0,8"/>

        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2">
            <CheckBox x:Name="StartWithWindowsCheckBox"
                      Content="Start with Windows"
                      Foreground="#BAC2DE" Margin="0,0,0,6"/>
            <CheckBox x:Name="StartMinimizedCheckBox"
                      Content="Start minimized to system tray"
                      Foreground="#BAC2DE" Margin="0,0,0,4"/>
        </StackPanel>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Width="90" Height="32" Click="Save_Click"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="90" Height="32" Click="Cancel_Click"
                    Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
