<Window x:Class="MeetingTranscriber.Views.MeetingDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meeting Details"
        Icon="/Resources/transcript.png"
        Width="800" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*" MinHeight="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="80"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" x:Name="TitleText"
                   FontSize="22" FontWeight="Bold" Foreground="#CDD6F4"
                   TextWrapping="Wrap" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" x:Name="TimeText"
                   FontSize="12" Foreground="#6C7086" Margin="0,0,0,12"/>

        <!-- Tab-like area -->
        <TabControl Grid.Row="2" Background="#181825" BorderBrush="#313244"
                    Foreground="#CDD6F4">
            <TabItem Header="Summary">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
                    <TextBlock x:Name="SummaryText" TextWrapping="Wrap"
                               Foreground="#BAC2DE" FontSize="14"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Transcript">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
                    <TextBlock x:Name="TranscriptText" TextWrapping="Wrap"
                               Foreground="#BAC2DE" FontSize="13"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Drag handle to resize between tabs and Q&A -->
        <GridSplitter Grid.Row="3" Height="6" HorizontalAlignment="Stretch"
                      Background="#45475A" ResizeBehavior="PreviousAndNext"
                      Cursor="SizeNS" Margin="0,4"/>

        <!-- Q&A panel -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Ask a question about this meeting:"
                           Foreground="#BAC2DE" FontSize="13" VerticalAlignment="Center"/>
                <Button Content="🗑 Delete Meeting" Click="Delete_Click"
                        Width="130" Height="28" Margin="16,0,0,0"
                        Background="#F38BA8" Foreground="#1E1E2E" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="QuestionBox"
                         Padding="8,6" FontSize="13"
                         Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"
                         KeyDown="QuestionBox_KeyDown"/>
                <Button Grid.Column="1" Content="Ask" Width="70" Height="32" Margin="8,0,0,0"
                        Click="Ask_Click"
                        Background="#89B4FA" Foreground="#1E1E2E" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand"/>
            </Grid>
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                <TextBlock x:Name="AnswerText" TextWrapping="Wrap"
                           Foreground="#A6E3A1" FontSize="13"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
