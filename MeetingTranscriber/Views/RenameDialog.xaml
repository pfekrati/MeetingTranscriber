<Window x:Class="MeetingTranscriber.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Meeting"
        Width="400" Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Enter a new name for the meeting:"
                   Foreground="#CDD6F4" FontSize="13" Margin="0,0,0,8"/>

        <TextBox Grid.Row="1" x:Name="NameBox"
                 Padding="8,6" FontSize="13"
                 Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Height="30" Margin="0,0,8,0"
                    Click="OK_Click" IsDefault="True"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="Cancel" Width="80" Height="30"
                    Click="Cancel_Click" IsCancel="True"
                    Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
